# Supabase project (leave empty to run the portal in demo mode with sample data)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# AWS upload API (presigned URL endpoint exposed by the cloud repo, optional)
NEXT_PUBLIC_UPLOAD_API_URL=

# Demo mode in PRODUCTION requires explicit opt-in (fail-closed).
# In development, leaving the Supabase vars empty already enables demo mode.
NEXT_PUBLIC_DEMO_MODE=
